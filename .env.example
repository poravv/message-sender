# ===============================
# Servidor
# ===============================
PORT=3000                                  # Puerto del servidor
NODE_ENV=production                        # production | development

# ===============================
# App
# ===============================
FILE_RETENTION_HOURS=24                    # Retención de archivos temporales (h)
MESSAGE_DELAY_MS=2000                      # Delay base entre mensajes (ms)
AUTHORIZED_PHONES=595992756462,595981123456  # Números autorizados (sin +)

# ===============================
# Firebase Auth (provide ONE of the following)
# ===============================
# Option A: base64-encoded service-account JSON (recommended for containers)
# FIREBASE_SERVICE_ACCOUNT=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Ii...
#
# Option B: path to service-account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# ===============================
# Persistencia de sesiones Baileys
# ===============================
# file  = sesiones locales en disco (no recomendado en Kubernetes)
# redis = sesiones centralizadas, apto para múltiples réplicas
SESSION_STORE=redis

# Redis (si SESSION_STORE=redis)
# Opción A: URL completa
# REDIS_URL=redis://:password@redis:6379/0
# Opción B: variables sueltas
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false                         # true si el proxy expone TLS
REDIS_TLS_REJECT_UNAUTHORIZED=true      # false para certificados self-signed en pruebas

# TTLs
REDIS_TTL_SECONDS=43200                     # 12 horas para credenciales/keys
REDIS_QR_TTL_SECONDS=180                    # 3 minutos para QR temporal

# ===============================
# PostgreSQL
# ===============================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=sender
POSTGRES_PASSWORD=changeme
POSTGRES_DB=sender_db

# ===============================
# S3 / MinIO (media storage)
# ===============================
# MINIO_ENDPOINT=http://minio:9000
# MINIO_REGION=us-east-1
# MINIO_EXTERNAL_ENDPOINT=https://s3.example.com
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_SECURE=false
# MINIO_BUCKET=message-sender
# MINIO_FORCE_PATH_STYLE=true
# MINIO_DELETE_AFTER_SEND=false

# ===============================
# Chatbot / AI Integration
# ===============================
# 32-byte hex key used to encrypt AI provider API keys (AES-256-CBC)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CHATBOT_ENCRYPTION_KEY=

# ===============================
# Logs (opcional)
# ===============================
# LOG_LEVEL=info
